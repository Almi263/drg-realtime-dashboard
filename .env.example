AUTH_SECRET=
AUTH_URL=http://localhost:3000

AUTH_MICROSOFT_ENTRA_ID_ID=         # Microsoft Entra ID Application (Client) ID
AUTH_MICROSOFT_ENTRA_ID_SECRET=     # Microsoft Entra ID Application Client Secret VALUE (not secret ID)
AUTH_MICROSOFT_ENTRA_ID_ISSUER=https://login.microsoftonline.com/<tenant-id>/v2.0

ENTRA_DRG_ADMIN_GROUP_ID=
ENTRA_DRG_PROGRAM_OWNER_GROUP_ID=
ENTRA_DRG_STAFF_GROUP_ID=
ENTRA_EXTERNAL_REVIEWER_GROUP_ID=

# Dataverse Web API (server-side only)
DATAVERSE_ENVIRONMENT_URL=https://<org>.crm.dynamics.com
# Optional alias supported by the app; use one URL variable, not both.
DATAVERSE_URL=
DATAVERSE_TENANT_ID=
DATAVERSE_CLIENT_ID=

# Use either a client secret...
DATAVERSE_CLIENT_SECRET=

# ...or certificate-based client credentials.
# Store PEM with escaped newlines in hosted environments.
DATAVERSE_CLIENT_CERTIFICATE_PRIVATE_KEY=
DATAVERSE_CLIENT_CERTIFICATE_THUMBPRINT=

# Usually https://<org>.crm.dynamics.com/.default
DATAVERSE_SCOPE=
# Optional legacy alias if your deployment uses resource naming.
DATAVERSE_RESOURCE=

# SharePoint PDF store (Microsoft Graph, server-side only)
SHAREPOINT_TENANT_ID=
SHAREPOINT_CLIENT_ID=
SHAREPOINT_CLIENT_SECRET=
SHAREPOINT_SITE_ID=
SHAREPOINT_SITE_URL=
SHAREPOINT_DRIVE_ID=
SHAREPOINT_DOCUMENT_FOLDER=DRG Submissions

# Power Automate workflow endpoints
POWER_AUTOMATE_SUBMISSION_CREATED_URL=
POWER_AUTOMATE_DOCUMENT_DOWNLOADED_URL=
POWER_AUTOMATE_APPROVAL_DECISION_SUBMITTED_URL=
POWER_AUTOMATE_PROGRAM_ACCESS_CHANGED_URL=

# Create a new app registration "DRG IMS Graph Invitations"

AZURE_TENANT_ID=
AZURE_GRAPH_CLIENT_ID=      # Application (client) ID
AZURE_GRAPH_CLIENT_SECRET=
APP_URL=http://localhost:3000
